# Copy this file to .env.local and fill in your values
# Add the same keys to your Railway dashboard → Variables tab

# Supabase (get from supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (get from aistudio.google.com)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Google Maps Geocoding (optional — only needed if Zippopotam.us fails for your region)
# Get from console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=

# App URL — set to your Railway domain in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
